      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "monad",
    "evm",
    "gas",
    "transaction-simulation",
    "preflight",
    "web3",
    "viem",
    "blockchain-security"
  ],
  "homepage": "https://reckon-monad-seatbelt.netlify.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeswithroh/reckon.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/codeswithroh/reckon/issues"
  },
  "author": "codeswithroh",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:live": "vitest run test/live"
  },
  "peerDependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "viem": "^2.21.0",
